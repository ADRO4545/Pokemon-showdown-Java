<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="700.0" prefWidth="900.0" spacing="40.0" style="-fx-background-color: #1a1f3c;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.FirstChooseController">
   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>

   <VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #2a3256; -fx-background-radius: 15; -fx-padding: 20;">
      <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #4a7af5;" text="Quel Pokémon voulez-vous envoyer en premier ?" />
      <HBox alignment="CENTER" spacing="30.0">
         
         <VBox alignment="CENTER" spacing="10.0">
            <ImageView fx:id="imgPlayer1" fitHeight="120.0" fitWidth="120.0" preserveRatio="true" />
            <Button fx:id="btnPlayer1" mnemonicParsing="false" onAction="#choosePokemon" style="-fx-background-color: #4a7af5; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Choisir" />
         </VBox>

         <VBox alignment="CENTER" spacing="10.0">
            <ImageView fx:id="imgPlayer2" fitHeight="120.0" fitWidth="120.0" preserveRatio="true" />
            <Button fx:id="btnPlayer2" mnemonicParsing="false" onAction="#choosePokemon" style="-fx-background-color: #4a7af5; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Choisir" />
         </VBox>

         <VBox alignment="CENTER" spacing="10.0">
            <ImageView fx:id="imgPlayer3" fitHeight="120.0" fitWidth="120.0" preserveRatio="true" />
            <Button fx:id="btnPlayer3" mnemonicParsing="false" onAction="#choosePokemon" style="-fx-background-color: #4a7af5; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Choisir" />
         </VBox>

         <VBox alignment="CENTER" spacing="10.0">
            <ImageView fx:id="imgPlayer4" fitHeight="120.0" fitWidth="120.0" preserveRatio="true" />
            <Button fx:id="btnPlayer4" mnemonicParsing="false" onAction="#choosePokemon" style="-fx-background-color: #4a7af5; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Choisir" />
         </VBox>

      </HBox>
   </VBox>
</VBox>