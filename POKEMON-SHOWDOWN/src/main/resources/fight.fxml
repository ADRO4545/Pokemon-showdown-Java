<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="850.0" prefWidth="1200.0" spacing="20.0" style="-fx-background-color: #1a1f3c;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.FightController">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>

   <HBox alignment="CENTER" spacing="30.0" VBox.vgrow="ALWAYS">
      
      <VBox alignment="CENTER" prefWidth="350.0" spacing="15.0" style="-fx-background-color: #2a3256; -fx-background-radius: 15; -fx-padding: 20;" HBox.hgrow="ALWAYS">
         <Label style="-fx-text-fill: #4a7af5; -fx-font-size: 22px; -fx-font-weight: bold;" text="Mon Pokémon" />
         <ImageView fx:id="imgPlayerActive" fitHeight="150.0" fitWidth="150.0" preserveRatio="true" />
         <Label fx:id="namePlayerActive" style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;" text="Nom du Pokémon" />
         <Label fx:id="typesPlayerActive" style="-fx-text-fill: #a0a0a0; -fx-font-size: 16px;" text="Type 1 / Type 2" />
         <Label fx:id="hpPlayerActive" style="-fx-text-fill: #4ade80; -fx-font-size: 20px; -fx-font-weight: bold;" text="HP : 100 / 100" />
         <Label fx:id="statusPlayerActive" style="-fx-text-fill: #fbbf24; -fx-font-size: 16px; -fx-font-weight: bold;" text="Statut : AUCUN" />
      </VBox>

      <VBox alignment="CENTER" prefWidth="350.0" spacing="15.0" style="-fx-background-color: #2a3256; -fx-background-radius: 15; -fx-padding: 20;" HBox.hgrow="ALWAYS">
         <Label style="-fx-text-fill: #f54a4a; -fx-font-size: 22px; -fx-font-weight: bold;" text="Pokémon Adverse" />
         <ImageView fx:id="imgEnemyActive" fitHeight="150.0" fitWidth="150.0" preserveRatio="true" />
         <Label fx:id="nameEnemyActive" style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;" text="Nom du Pokémon" />
         <Label fx:id="typesEnemyActive" style="-fx-text-fill: #a0a0a0; -fx-font-size: 16px;" text="Type 1 / Type 2" />
         <Label fx:id="hpEnemyActive" style="-fx-text-fill: #4ade80; -fx-font-size: 20px; -fx-font-weight: bold;" text="HP : 100 / 100" />
         <Label fx:id="statusEnemyActive" style="-fx-text-fill: #fbbf24; -fx-font-size: 16px; -fx-font-weight: bold;" text="Statut : AUCUN" />
      </VBox>

      <VBox prefWidth="350.0" spacing="10.0" style="-fx-background-color: #2a3256; -fx-background-radius: 15; -fx-padding: 15;">
         <Label style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" text="Historique du combat" />
         <TextArea fx:id="historyLog" editable="false" wrapText="true" VBox.vgrow="ALWAYS" style="-fx-font-size: 14px;" />
      </VBox>

   </HBox>

   <VBox alignment="CENTER" spacing="25.0" style="-fx-background-color: #2a3256; -fx-background-radius: 15; -fx-padding: 20;">
      
      <VBox alignment="CENTER" spacing="10.0">
         <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Attaques disponibles" />
         <HBox alignment="CENTER" spacing="20.0">
            <Button fx:id="btnAtk1" prefHeight="60.0" prefWidth="220.0" style="-fx-background-color: #f54a4a; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-cursor: hand;" text="Attaque 1" />
            <Button fx:id="btnAtk2" prefHeight="60.0" prefWidth="220.0" style="-fx-background-color: #f54a4a; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-cursor: hand;" text="Attaque 2" />
            <Button fx:id="btnAtk3" prefHeight="60.0" prefWidth="220.0" style="-fx-background-color: #f54a4a; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-cursor: hand;" text="Attaque 3" />
            <Button fx:id="btnAtk4" prefHeight="60.0" prefWidth="220.0" style="-fx-background-color: #f54a4a; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-cursor: hand;" text="Attaque 4" />
         </HBox>
      </VBox>

      <VBox alignment="CENTER" spacing="10.0">
         <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Mon Deck" />
         <HBox alignment="CENTER" spacing="20.0">
            <Button fx:id="btnSwitch1" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: #4a7af5; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;" text="Pokémon 1" />
            <Button fx:id="btnSwitch2" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: #4a7af5; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;" text="Pokémon 2" />
            <Button fx:id="btnSwitch3" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: #4a7af5; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;" text="Pokémon 3" />
            <Button fx:id="btnSwitch4" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: #4a7af5; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;" text="Pokémon 4" />
         </HBox>
      </VBox>

   </VBox>

</VBox>