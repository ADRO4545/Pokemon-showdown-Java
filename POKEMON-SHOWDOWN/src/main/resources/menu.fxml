<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.MenuController"
      alignment="CENTER" spacing="30"
      prefHeight="400.0" prefWidth="800.0"
      style="-fx-background-color: #1a1f3c;">

    <!-- Titre jaune -->
    <Label text="Pokemon Battle"
           style="-fx-font-size: 28px;
                  -fx-font-weight: bold;
                  -fx-text-fill: #f5d800;" />

    <!-- Bouton bleu arrondi -->
    <Button text="Démarrer un combat"
            prefWidth="340" prefHeight="55"
            style="-fx-background-color: #4a7af5;
                   -fx-text-fill: white;
                   -fx-font-size: 16px;
                   -fx-font-weight: bold;
                   -fx-background-radius: 10;
                   -fx-cursor: hand;" />

    <!-- Copyright en bas -->
    <Label text="© 2026 Pokémon Battle Simulator. Arthur Drugeault, Pierre Soreau."
           style="-fx-font-size: 11px;
                  -fx-text-fill: #8888aa;" />

</VBox>