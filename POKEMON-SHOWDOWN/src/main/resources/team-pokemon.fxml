<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="40.0" prefHeight="700.0" prefWidth="1100.0"
      style="-fx-background-color: #1a1f3c;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.TeamController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <VBox alignment="TOP_CENTER" spacing="30.0"
          style="-fx-background-color: #2a3256; -fx-background-radius: 15; -fx-padding: 30;">
        
        <Label text="Équipe 1" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #4a7af5;" />

        <HBox alignment="CENTER" spacing="20.0">

            <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: #3b446b; -fx-background-radius: 10; -fx-padding: 15;">
                <ImageView fx:id="imgT1P1" fitHeight="100.0" fitWidth="100.0" preserveRatio="true" />
                <Label fx:id="nomT1P1" text="?" style="-fx-text-fill: white; -fx-font-weight: bold;" />
                <ComboBox fx:id="comboT1P1" promptText="Choisir un Pokémon" prefWidth="150.0" onAction="#putPokemon"/>
                <ComboBox fx:id="itemT1P1" promptText="Objet tenu" prefWidth="150.0" />
                <ComboBox fx:id="atk1T1P1" promptText="Atk 1" prefWidth="150"/>
                <ComboBox fx:id="atk2T1P1" promptText="Atk 2" prefWidth="150"/>
                <ComboBox fx:id="atk3T1P1" promptText="Atk 3" prefWidth="150"/>
                <ComboBox fx:id="atk4T1P1" promptText="Atk 4" prefWidth="150"/>
            </VBox>

            <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: #3b446b; -fx-background-radius: 10; -fx-padding: 15;">
                <ImageView fx:id="imgT1P2" fitHeight="100.0" fitWidth="100.0" preserveRatio="true" />
                <Label fx:id="nomT1P2" text="?" style="-fx-text-fill: white; -fx-font-weight: bold;" />
                <ComboBox fx:id="comboT1P2" promptText="Choisir un Pokémon" prefWidth="150.0" onAction="#putPokemon" />
                <ComboBox fx:id="itemT1P2" promptText="Objet tenu" prefWidth="150.0" />
                <ComboBox fx:id="atk1T1P2" promptText="Atk 1" prefWidth="150"/>
                <ComboBox fx:id="atk2T1P2" promptText="Atk 2" prefWidth="150"/>
                <ComboBox fx:id="atk3T1P2" promptText="Atk 3" prefWidth="150"/>
                <ComboBox fx:id="atk4T1P2" promptText="Atk 4" prefWidth="150"/>
            </VBox>

            <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: #3b446b; -fx-background-radius: 10; -fx-padding: 15;">
                <ImageView fx:id="imgT1P3" fitHeight="100.0" fitWidth="100.0" preserveRatio="true" />
                <Label fx:id="nomT1P3" text="?" style="-fx-text-fill: white; -fx-font-weight: bold;" />
                <ComboBox fx:id="comboT1P3" promptText="Choisir un Pokémon" prefWidth="150.0" onAction="#putPokemon" />
                <ComboBox fx:id="itemT1P3" promptText="Objet tenu" prefWidth="150.0" />
                <ComboBox fx:id="atk1T1P3" promptText="Atk 1" prefWidth="150"/>
                <ComboBox fx:id="atk2T1P3" promptText="Atk 2" prefWidth="150"/>
                <ComboBox fx:id="atk3T1P3" promptText="Atk 3" prefWidth="150"/>
                <ComboBox fx:id="atk4T1P3" promptText="Atk 4" prefWidth="150"/>
            </VBox>

            <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: #3b446b; -fx-background-radius: 10; -fx-padding: 15;">
                <ImageView fx:id="imgT1P4" fitHeight="100.0" fitWidth="100.0" preserveRatio="true" />
                <Label fx:id="nomT1P4" text="?" style="-fx-text-fill: white; -fx-font-weight: bold;" />
                <ComboBox fx:id="comboT1P4" promptText="Choisir un Pokémon" prefWidth="150.0" onAction="#putPokemon" />
                <ComboBox fx:id="itemT1P4" promptText="Objet tenu" prefWidth="150.0" />
                <ComboBox fx:id="atk1T1P4" promptText="Atk 1" prefWidth="150"/>
                <ComboBox fx:id="atk2T1P4" promptText="Atk 2" prefWidth="150"/>
                <ComboBox fx:id="atk3T1P4" promptText="Atk 3" prefWidth="150"/>
                <ComboBox fx:id="atk4T1P4" promptText="Atk 4" prefWidth="150"/>
            </VBox>

        </HBox>
    </VBox>

    <Button text="COMBATTRE !" onAction="#startBattle"
            prefWidth="300.0" prefHeight="60.0"
            style="-fx-background-color: #f54a4a;
                   -fx-text-fill: white;
                   -fx-font-size: 24px;
                   -fx-font-weight: bold;
                   -fx-background-radius: 30;
                   -fx-cursor: hand;" />

</VBox>